    "input.placeholderForeground": "#f3b4bf88",
    "inputOption.activeBackground": "#fe7c8e44",
    "inputOption.activeBorder": "#fe7c8e",
    "inputOption.activeForeground": "#fff8f8",
    "list.activeSelectionBackground": "#472541",
